# rfnry-knowledge ships no provider implementations and reads no provider API
# keys from the environment. The host application owns ProviderClient
# construction, including credential lookup. This file lists only the
# library-internal toggles.

KNWL_LOG_ENABLED=false
KNWL_LOG_LEVEL=INFO
KNWL_LOG_QUERIES=false
KNWL_BAML_LOG=warn
